/*
  # ─── Security Headers for Cloudflare Pages ─────────────────────────────
  #
  # Applied to every response from this site.
  # For GitHub Pages: add equivalent rules via Cloudflare Transform Rules
  # in the Cloudflare dashboard after pointing DNS.

  # Prevent clickjacking — no one can embed this site in an iframe
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Limit referrer information shared with third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser APIs not used by this site
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # Cross-origin isolation
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # Content Security Policy
  # - Fonts, styles: self-hosted
  # - Scripts: self + Google Tag Manager (GA4); inline required for gtag init
  # - Connect: Google Analytics endpoints for event/beacon sending
  # - Images: self + GA pixel endpoints
  # - frame-ancestors 'none': redundant with X-Frame-Options but belt-and-suspenders
  Content-Security-Policy: default-src 'none'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; script-src 'self' https://www.googletagmanager.com 'unsafe-inline'; connect-src https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://region1.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'mailto:'
